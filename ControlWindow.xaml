<Window x:Class="FieldHockeyScoreboard.ControlWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Хоккей на траве — Управление"
        Width="700" MinWidth="500" SizeToContent="Height"
        Left="0" Top="270"
        ResizeMode="CanResizeWithGrip"
        Background="#2d2d44">

    <Window.Resources>
        <Style x:Key="BtnStyle" TargetType="Button">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#0f3460"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1a5276"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0b2545"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnStyle}">
            <Setter Property="Background" Value="#e94560"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#c0392b"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnGreen" TargetType="Button" BasedOn="{StaticResource BtnStyle}">
            <Setter Property="Background" Value="#2ecc71"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#27ae60"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#aaa"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="12">

        <!-- Title -->
        <TextBlock Text="ХОККЕЙ НА ТРАВЕ — УПРАВЛЕНИЕ"
                   FontSize="20" FontWeight="Bold" Foreground="#e94560"
                   HorizontalAlignment="Center" Margin="0,0,0,12"/>

        <!-- Team Names -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Команда А" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TxtTeamA" Style="{StaticResource InputStyle}"
                         Text="{Binding TeamAName, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Команда Б" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="TxtTeamB" Style="{StaticResource InputStyle}"
                         Text="{Binding TeamBName, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </Grid>

        <!-- Score Controls -->
        <Border Background="#1a1a2e" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Team A Score -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="ГОЛЫ А" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="−" Width="50" Height="42" Style="{StaticResource BtnDanger}"
                                Click="ScoreAMinus_Click"/>
                        <TextBlock Text="{Binding ScoreA}" FontSize="30" FontWeight="Bold"
                                   Foreground="White" Margin="10,0" VerticalAlignment="Center"/>
                        <Button Content="+" Width="50" Height="42" Style="{StaticResource BtnGreen}"
                                Click="ScoreAPlus_Click"/>
                    </StackPanel>
                </StackPanel>

                <!-- Score Display -->
                <TextBlock Grid.Column="1" Text="{Binding ScoreDisplay}"
                           FontSize="28" FontWeight="Bold" Foreground="#e94560"
                           VerticalAlignment="Center" Margin="15,0"/>

                <!-- Team B Score -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="ГОЛЫ Б" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="−" Width="50" Height="42" Style="{StaticResource BtnDanger}"
                                Click="ScoreBMinus_Click"/>
                        <TextBlock Text="{Binding ScoreB}" FontSize="30" FontWeight="Bold"
                                   Foreground="White" Margin="10,0" VerticalAlignment="Center"/>
                        <Button Content="+" Width="50" Height="42" Style="{StaticResource BtnGreen}"
                                Click="ScoreBPlus_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Cards Controls -->
        <Border Background="#1a1a2e" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Cards A -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Карточки А" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,3">
                        <Ellipse Width="12" Height="12" Fill="#2ecc71" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <Button Content="−" Width="38" Height="34" Style="{StaticResource BtnStyle}"
                                Click="GreenAMinus_Click"/>
                        <TextBlock Text="{Binding GreenCardsA}" FontSize="16" Foreground="White"
                                   Margin="5,0" VerticalAlignment="Center"/>
                        <Button Content="+" Width="38" Height="34" Style="{StaticResource BtnStyle}"
                                Click="GreenAPlus_Click"/>
                        <Ellipse Width="12" Height="12" Fill="#f1c40f" Margin="10,0,5,0" VerticalAlignment="Center"/>
                        <Button Content="−" Width="38" Height="34" Style="{StaticResource BtnStyle}"
                                Click="YellowAMinus_Click"/>
                        <TextBlock Text="{Binding YellowCardsA}" FontSize="16" Foreground="White"
                                   Margin="5,0" VerticalAlignment="Center"/>
                        <Button Content="+" Width="38" Height="34" Style="{StaticResource BtnStyle}"
                                Click="YellowAPlus_Click"/>
                    </StackPanel>
                </StackPanel>

                <!-- Cards B -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Карточки Б" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,3">
                        <Ellipse Width="12" Height="12" Fill="#2ecc71" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <Button Content="−" Width="38" Height="34" Style="{StaticResource BtnStyle}"
                                Click="GreenBMinus_Click"/>
                        <TextBlock Text="{Binding GreenCardsB}" FontSize="16" Foreground="White"
                                   Margin="5,0" VerticalAlignment="Center"/>
                        <Button Content="+" Width="38" Height="34" Style="{StaticResource BtnStyle}"
                                Click="GreenBPlus_Click"/>
                        <Ellipse Width="12" Height="12" Fill="#f1c40f" Margin="10,0,5,0" VerticalAlignment="Center"/>
                        <Button Content="−" Width="38" Height="34" Style="{StaticResource BtnStyle}"
                                Click="YellowBMinus_Click"/>
                        <TextBlock Text="{Binding YellowCardsB}" FontSize="16" Foreground="White"
                                   Margin="5,0" VerticalAlignment="Center"/>
                        <Button Content="+" Width="38" Height="34" Style="{StaticResource BtnStyle}"
                                Click="YellowBPlus_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Timer Controls -->
        <Border Background="#1a1a2e" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="ТАЙМЕР" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding TimerDisplay}" FontSize="28" FontWeight="Bold"
                           Foreground="#e94560" HorizontalAlignment="Center" Margin="0,5"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                    <Button x:Name="BtnStartPause" Content="СТАРТ" Width="110" Height="42"
                            Style="{StaticResource BtnGreen}" Click="StartPause_Click"/>
                    <Button Content="СБРОС" Width="110" Height="42"
                            Style="{StaticResource BtnStyle}" Click="ResetTimer_Click"/>
                    <TextBlock Text="Минуты:" Foreground="#aaa" VerticalAlignment="Center" Margin="10,0,5,0"/>
                    <TextBox x:Name="TxtMinutes" Width="50" Style="{StaticResource InputStyle}"
                             Text="35" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                    <Button Content="SET" Width="55" Height="42"
                            Style="{StaticResource BtnStyle}" Click="SetTimer_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Period Controls -->
        <Border Background="#1a1a2e" CornerRadius="5" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="ПЕРИОД" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
                    <Button Content="1 ТАЙМ" Width="110" Height="38" Style="{StaticResource BtnStyle}"
                            Click="Period1_Click"/>
                    <Button Content="ПЕРЕРЫВ" Width="110" Height="38" Style="{StaticResource BtnStyle}"
                            Click="PeriodBreak_Click"/>
                    <Button Content="2 ТАЙМ" Width="110" Height="38" Style="{StaticResource BtnStyle}"
                            Click="Period2_Click"/>
                    <Button Content="БУЛЛИТЫ" Width="110" Height="38" Style="{StaticResource BtnDanger}"
                            Click="PeriodShootout_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Bottom Controls -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5">
            <Button x:Name="BtnMonitor" Content="&#x1F5B5; 2-й МОНИТОР" Height="42"
                    Style="{StaticResource BtnStyle}" Click="MoveToMonitor_Click" Padding="16,6"/>
            <Button Content="&#x26A0; СБРОС МАТЧА" Height="42"
                    Style="{StaticResource BtnDanger}" Click="ResetMatch_Click" Padding="16,6"/>
        </StackPanel>
    </StackPanel>
</Window>
