<Window x:Class="FieldHockeyScoreboard.ScoreboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Aliased"
        Title="Табло"
        Width="560" Height="240"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        Left="0" Top="0"
        AllowsTransparency="False"
        Background="#000000"
        ShowInTaskbar="False">

    <Window.Resources>
        <FontFamily x:Key="Seg7">pack://application:,,,/Fonts/#DSEG7 Classic</FontFamily>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="54"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="42"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Team Names — 2 строки, крупно -->
        <Grid Grid.Row="0" Margin="6,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Team A: название + город -->
            <TextBlock Grid.Column="0" Text="{Binding TeamAName}"
                       FontFamily="Consolas" FontSize="22" FontWeight="Bold"
                       Foreground="#FFFFFF"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxHeight="54"
                       LineHeight="26" LineStackingStrategy="BlockLineHeight"/>

            <!-- Team B: название + город -->
            <TextBlock Grid.Column="1" Text="{Binding TeamBName}"
                       FontFamily="Consolas" FontSize="22" FontWeight="Bold"
                       Foreground="#FFFFFF"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       MaxHeight="54"
                       LineHeight="26" LineStackingStrategy="BlockLineHeight"/>
        </Grid>

        <!-- Row 1: Period -->
        <Border Grid.Row="1" Background="#0a0a0a">
            <TextBlock Text="{Binding Period}"
                       FontFamily="Consolas"
                       FontSize="26" FontWeight="Bold"
                       Foreground="#FF3333"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Row 2: Logo A + SCORE + Logo B -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="74"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="74"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" Source="{Binding LogoASource}"
                   Width="68" Height="68" Stretch="Uniform"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>

            <Viewbox Grid.Column="1" Stretch="Uniform" Margin="2,2">
                <TextBlock Text="{Binding ScoreDisplay}"
                           FontFamily="{StaticResource Seg7}"
                           Foreground="#FFCC00"/>
            </Viewbox>

            <Image Grid.Column="2" Source="{Binding LogoBSource}"
                   Width="68" Height="68" Stretch="Uniform"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
        </Grid>

        <!-- Row 3: Timer only -->
        <Border Grid.Row="3" Background="#0a0a0a">
            <TextBlock Text="{Binding TimerDisplay}"
                       FontFamily="{StaticResource Seg7}"
                       FontSize="36"
                       Foreground="#FF3333"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
