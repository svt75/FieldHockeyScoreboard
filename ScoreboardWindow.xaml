<Window x:Class="FieldHockeyScoreboard.ScoreboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Aliased"
        SnapsToDevicePixels="True"
        Title="Табло"
        Width="560" Height="240"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        Left="0" Top="0"
        AllowsTransparency="False"
        Background="#000000"
        ShowInTaskbar="False">

    <Window.Resources>
        <FontFamily x:Key="Seg7">pack://application:,,,/Fonts/#DSEG7 Classic</FontFamily>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="68"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Team names (2 lines) + Period -->
        <Border Grid.Row="0" Background="#0a0a0a">
            <Grid Margin="8,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TeamAName}"
                               FontFamily="Consolas" FontSize="26" FontWeight="Bold"
                               Foreground="#FFFFFF"
                               SnapsToDevicePixels="True"
                               TextOptions.TextRenderingMode="Aliased"
                               TextOptions.TextFormattingMode="Display"
                               HorizontalAlignment="Left"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding TeamACityName}"
                               FontFamily="Consolas" FontSize="20" FontWeight="Bold"
                               Foreground="#FF3333"
                               SnapsToDevicePixels="True"
                               TextOptions.TextRenderingMode="Aliased"
                               TextOptions.TextFormattingMode="Display"
                               HorizontalAlignment="Left"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="{Binding Period}"
                           FontFamily="Consolas" FontSize="22" FontWeight="Bold"
                           Foreground="#FF3333"
                           SnapsToDevicePixels="True"
                           TextOptions.TextRenderingMode="Aliased"
                           TextOptions.TextFormattingMode="Display"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="12,0"/>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding TeamBName}"
                               FontFamily="Consolas" FontSize="26" FontWeight="Bold"
                               Foreground="#FFFFFF"
                               SnapsToDevicePixels="True"
                               TextOptions.TextRenderingMode="Aliased"
                               TextOptions.TextFormattingMode="Display"
                               HorizontalAlignment="Right"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding TeamBCityName}"
                               FontFamily="Consolas" FontSize="20" FontWeight="Bold"
                               Foreground="#FF3333"
                               SnapsToDevicePixels="True"
                               TextOptions.TextRenderingMode="Aliased"
                               TextOptions.TextFormattingMode="Display"
                               HorizontalAlignment="Right"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Logos: span rows 1+2, anchored to bottom, behind score and timer -->
        <Image Grid.Row="1" Grid.RowSpan="2"
               Source="{Binding LogoASource}"
               Width="110" Height="110" Stretch="Uniform"
               HorizontalAlignment="Left" VerticalAlignment="Bottom"
               Margin="4,0,0,4"
               RenderOptions.BitmapScalingMode="NearestNeighbor"/>

        <Image Grid.Row="1" Grid.RowSpan="2"
               Source="{Binding LogoBSource}"
               Width="110" Height="110" Stretch="Uniform"
               HorizontalAlignment="Right" VerticalAlignment="Bottom"
               Margin="0,0,4,4"
               RenderOptions.BitmapScalingMode="NearestNeighbor"/>

        <!-- Row 1: Score (center, over logos) -->
        <Viewbox Grid.Row="1" Stretch="Uniform" Margin="110,2,110,2">
            <TextBlock Text="{Binding ScoreDisplay}"
                       FontFamily="{StaticResource Seg7}"
                       Foreground="#FFCC00"/>
        </Viewbox>

        <!-- Row 2: Timer (center) -->
        <Border Grid.Row="2" Background="#0a0a0a">
            <TextBlock Text="{Binding TimerDisplay}"
                       FontFamily="{StaticResource Seg7}"
                       FontSize="44"
                       Foreground="#FF3333"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
