<Window x:Class="FieldHockeyScoreboard.ScoreboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Aliased"
        Title="Табло"
        Width="560" Height="240"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        Left="0" Top="0"
        AllowsTransparency="False"
        Background="#000000"
        ShowInTaskbar="False">

    <Window.Resources>
        <FontFamily x:Key="Seg7">pack://application:,,,/Fonts/#DSEG7 Classic</FontFamily>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="38"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Logo + Team names (28px, wrap up to 3 lines) -->
        <Grid Grid.Row="0" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="76" MinWidth="76" MaxWidth="76"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="76" MinWidth="76" MaxWidth="76"/>
            </Grid.ColumnDefinitions>

            <!-- Logo A -->
            <Border Grid.Column="0" Width="76" Height="76">
                <Image Source="{Binding LogoASource}"
                       Width="70" Height="70" Stretch="Uniform"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
            </Border>

            <!-- Team A name (wraps) -->
            <TextBlock Grid.Column="1" Text="{Binding TeamAName}"
                       FontFamily="Consolas" FontSize="28" FontWeight="Bold"
                       Foreground="#FFFFFF"
                       SnapsToDevicePixels="True"
                       TextOptions.TextRenderingMode="Aliased"
                       TextOptions.TextFormattingMode="Display"
                       HorizontalAlignment="Left" VerticalAlignment="Center"
                       TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                       Margin="4,0,4,0"
                       MaxHeight="80"
                       LineHeight="28" LineStackingStrategy="BlockLineHeight"/>

            <!-- Team B name (wraps) -->
            <TextBlock Grid.Column="2" Text="{Binding TeamBName}"
                       FontFamily="Consolas" FontSize="28" FontWeight="Bold"
                       Foreground="#FFFFFF"
                       SnapsToDevicePixels="True"
                       TextOptions.TextRenderingMode="Aliased"
                       TextOptions.TextFormattingMode="Display"
                       HorizontalAlignment="Right" VerticalAlignment="Center"
                       TextAlignment="Right"
                       TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                       Margin="4,0,4,0"
                       MaxHeight="80"
                       LineHeight="28" LineStackingStrategy="BlockLineHeight"/>

            <!-- Logo B -->
            <Border Grid.Column="3" Width="76" Height="76">
                <Image Source="{Binding LogoBSource}"
                       Width="70" Height="70" Stretch="Uniform"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
            </Border>
        </Grid>

        <!-- Row 1: Period -->
        <Border Grid.Row="1" Background="#0a0a0a" SnapsToDevicePixels="True">
            <TextBlock Text="{Binding Period}"
                       FontFamily="Consolas"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#FF3333"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       SnapsToDevicePixels="True"
                       TextOptions.TextRenderingMode="Aliased"
                       TextOptions.TextFormattingMode="Display"/>
        </Border>

        <!-- Row 2: Score (Viewbox, ~98px) -->
        <Viewbox Grid.Row="2" Stretch="Uniform" Margin="20,2">
            <TextBlock Text="{Binding ScoreDisplay}"
                       FontFamily="{StaticResource Seg7}"
                       Foreground="#FFCC00"/>
        </Viewbox>

        <!-- Row 3: Timer -->
        <Border Grid.Row="3" Background="#0a0a0a">
            <TextBlock Text="{Binding TimerDisplay}"
                       FontFamily="{StaticResource Seg7}"
                       FontSize="30"
                       Foreground="#FF3333"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
