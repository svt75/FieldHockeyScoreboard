<Window x:Class="FieldHockeyScoreboard.ScoreboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Aliased"
        SnapsToDevicePixels="True"
        Title="Табло"
        Width="560" Height="240"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        Left="0" Top="0"
        AllowsTransparency="False"
        Background="#000000"
        ShowInTaskbar="False">

    <Window.Resources>
        <FontFamily x:Key="Seg7">pack://application:,,,/Fonts/#DSEG7 Classic</FontFamily>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="34"/>
            <RowDefinition Height="22"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="42"/>
            <RowDefinition Height="34"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Team names — full width, 28px -->
        <Grid Grid.Row="0" Margin="8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{Binding TeamAName}"
                       FontFamily="Consolas" FontSize="28" FontWeight="Bold"
                       Foreground="#FFFFFF"
                       SnapsToDevicePixels="True"
                       TextOptions.TextRenderingMode="Aliased"
                       TextOptions.TextFormattingMode="Display"
                       HorizontalAlignment="Left" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>

            <TextBlock Grid.Column="1" Text="{Binding TeamBName}"
                       FontFamily="Consolas" FontSize="28" FontWeight="Bold"
                       Foreground="#FFFFFF"
                       SnapsToDevicePixels="True"
                       TextOptions.TextRenderingMode="Aliased"
                       TextOptions.TextFormattingMode="Display"
                       HorizontalAlignment="Right" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- Row 1: Period — narrow separate row -->
        <Border Grid.Row="1" Background="#0a0a0a">
            <TextBlock Text="{Binding Period}"
                       FontFamily="Consolas" FontSize="18" FontWeight="Bold"
                       Foreground="#FF3333"
                       SnapsToDevicePixels="True"
                       TextOptions.TextRenderingMode="Aliased"
                       TextOptions.TextFormattingMode="Display"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Row 2: Logo A | Score | Logo B -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="110"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" Source="{Binding LogoASource}"
                   Stretch="Uniform" Margin="4"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>

            <TextBlock Grid.Column="1"
                       Text="{Binding ScoreDisplay}"
                       FontFamily="{StaticResource Seg7}"
                       FontSize="80"
                       Foreground="#FFCC00"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       SnapsToDevicePixels="True"
                       TextOptions.TextRenderingMode="Aliased"
                       TextOptions.TextFormattingMode="Display"/>

            <Image Grid.Column="2" Source="{Binding LogoBSource}"
                   Stretch="Uniform" Margin="4"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
        </Grid>

        <!-- Row 3: Timer -->
        <Border Grid.Row="3" Background="#0a0a0a">
            <TextBlock Text="{Binding TimerDisplay}"
                       FontFamily="{StaticResource Seg7}"
                       FontSize="36"
                       Foreground="#FF3333"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       SnapsToDevicePixels="True"
                       TextOptions.TextRenderingMode="Aliased"
                       TextOptions.TextFormattingMode="Display"/>
        </Border>

        <!-- Row 4: City names — full width, 28px -->
        <Grid Grid.Row="4" Margin="8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{Binding TeamACityName}"
                       FontFamily="Consolas" FontSize="28" FontWeight="Bold"
                       Foreground="#FF3333"
                       SnapsToDevicePixels="True"
                       TextOptions.TextRenderingMode="Aliased"
                       TextOptions.TextFormattingMode="Display"
                       HorizontalAlignment="Left" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>

            <TextBlock Grid.Column="1" Text="{Binding TeamBCityName}"
                       FontFamily="Consolas" FontSize="28" FontWeight="Bold"
                       Foreground="#FF3333"
                       SnapsToDevicePixels="True"
                       TextOptions.TextRenderingMode="Aliased"
                       TextOptions.TextFormattingMode="Display"
                       HorizontalAlignment="Right" VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>
    </Grid>
</Window>
