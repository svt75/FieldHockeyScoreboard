<Window x:Class="FieldHockeyScoreboard.ScoreboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Aliased"
        SnapsToDevicePixels="True"
        Title="Табло"
        Width="560" Height="240"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        Left="0" Top="0"
        AllowsTransparency="False"
        Background="#000000"
        ShowInTaskbar="False">

    <Window.Resources>
        <FontFamily x:Key="Seg7">pack://application:,,,/Fonts/#DSEG7 Classic</FontFamily>
    </Window.Resources>

    <Grid>
        <!-- 5 rows: names 40 + period 40 + score 120 + timer 40 = 240 -->
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <!-- 3 columns: logo 130 + center 300 + logo 130 = 560 -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="130"/>
        </Grid.ColumnDefinitions>

        <!-- Row 0: Team names — span all 3 columns, split 280+280 -->
        <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{Binding TeamAName}"
                       FontFamily="Consolas" FontSize="30" FontWeight="Bold"
                       Foreground="#FFFFFF"
                       SnapsToDevicePixels="True"
                       TextOptions.TextRenderingMode="Aliased"
                       TextOptions.TextFormattingMode="Display"
                       HorizontalAlignment="Left" VerticalAlignment="Center"
                       Margin="8,0,0,0"
                       TextTrimming="CharacterEllipsis"/>

            <TextBlock Grid.Column="1" Text="{Binding TeamBName}"
                       FontFamily="Consolas" FontSize="30" FontWeight="Bold"
                       Foreground="#FFFFFF"
                       SnapsToDevicePixels="True"
                       TextOptions.TextRenderingMode="Aliased"
                       TextOptions.TextFormattingMode="Display"
                       HorizontalAlignment="Right" VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       TextTrimming="CharacterEllipsis"/>
        </Grid>

        <!-- Row 1: Period — center column only (300px) -->
        <Border Grid.Row="1" Grid.Column="1" Background="#0a0a0a">
            <TextBlock Text="{Binding Period}"
                       FontFamily="Consolas" FontSize="22" FontWeight="Bold"
                       Foreground="#FF3333"
                       SnapsToDevicePixels="True"
                       TextOptions.TextRenderingMode="Aliased"
                       TextOptions.TextFormattingMode="Display"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Row 2: Score — center column only (300px) -->
        <TextBlock Grid.Row="2" Grid.Column="1"
                   Text="{Binding ScoreDisplay}"
                   FontFamily="{StaticResource Seg7}"
                   FontSize="70"
                   Foreground="#FFCC00"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   SnapsToDevicePixels="True"
                   TextOptions.TextRenderingMode="Aliased"
                   TextOptions.TextFormattingMode="Display"/>

        <!-- Row 3: Timer — center column only (300px) -->
        <Border Grid.Row="3" Grid.Column="1" Background="#0a0a0a">
            <TextBlock Text="{Binding TimerDisplay}"
                       FontFamily="{StaticResource Seg7}"
                       FontSize="30"
                       Foreground="#FF3333"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       SnapsToDevicePixels="True"
                       TextOptions.TextRenderingMode="Aliased"
                       TextOptions.TextFormattingMode="Display"/>
        </Border>

        <!-- Logo A: spans rows 1+2+3 (40+120+40=200px), column 0 (130px) -->
        <Image Grid.Row="1" Grid.RowSpan="3" Grid.Column="0"
               Source="{Binding LogoASource}"
               Stretch="Uniform" Margin="6"
               HorizontalAlignment="Center" VerticalAlignment="Center"
               RenderOptions.BitmapScalingMode="NearestNeighbor"/>

        <!-- Logo B: spans rows 1+2+3 (40+120+40=200px), column 2 (130px) -->
        <Image Grid.Row="1" Grid.RowSpan="3" Grid.Column="2"
               Source="{Binding LogoBSource}"
               Stretch="Uniform" Margin="6"
               HorizontalAlignment="Center" VerticalAlignment="Center"
               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
    </Grid>
</Window>
