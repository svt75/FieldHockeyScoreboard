<Window x:Class="FieldHockeyScoreboard.ScoreboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Aliased"
        Title="Табло"
        Width="540" Height="260"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        Left="0" Top="0"
        AllowsTransparency="False"
        Background="#000000"
        ShowInTaskbar="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="28"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="46"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Period -->
        <Border Grid.Row="0" Background="#111111">
            <TextBlock Text="{Binding Period}"
                       FontFamily="Consolas"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#FF4444"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Row 1: Logos + Teams + Score -->
        <Grid Grid.Row="1" Margin="4,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="130"/>
            </Grid.ColumnDefinitions>

            <!-- Team A: logo + name -->
            <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Source="{Binding LogoASource}" Width="50" Height="50"
                       Stretch="Uniform" HorizontalAlignment="Center"
                       Margin="0,0,0,4" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                <TextBlock Text="{Binding TeamAName}"
                           FontFamily="Consolas"
                           FontSize="16" FontWeight="Bold"
                           Foreground="#FFFFFF"
                           HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="126"/>
            </StackPanel>

            <!-- Score — максимально крупно -->
            <Viewbox Grid.Column="1" Stretch="Uniform" Margin="0,8">
                <TextBlock Text="{Binding ScoreDisplay}"
                           FontFamily="Consolas"
                           FontWeight="Bold"
                           Foreground="#FFFF00"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Viewbox>

            <!-- Team B: logo + name -->
            <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Source="{Binding LogoBSource}" Width="50" Height="50"
                       Stretch="Uniform" HorizontalAlignment="Center"
                       Margin="0,0,0,4" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                <TextBlock Text="{Binding TeamBName}"
                           FontFamily="Consolas"
                           FontSize="16" FontWeight="Bold"
                           Foreground="#FFFFFF"
                           HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="126"/>
            </StackPanel>
        </Grid>

        <!-- Row 2: Cards + Timer -->
        <Border Grid.Row="2" Background="#111111">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Cards A -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" Fill="#00FF00" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding GreenCardsA}" FontFamily="Consolas" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <Ellipse Width="16" Height="16" Fill="#FFFF00" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding YellowCardsA}" FontFamily="Consolas" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Timer — крупно -->
                <Border Grid.Column="1" Background="#1a0000" Padding="16,2" Margin="8,4">
                    <TextBlock Text="{Binding TimerDisplay}"
                               FontFamily="Consolas"
                               FontSize="34" FontWeight="Bold"
                               Foreground="#FF4444"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Cards B -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" Fill="#00FF00" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding GreenCardsB}" FontFamily="Consolas" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <Ellipse Width="16" Height="16" Fill="#FFFF00" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding YellowCardsB}" FontFamily="Consolas" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
