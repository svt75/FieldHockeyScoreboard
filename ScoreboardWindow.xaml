<Window x:Class="FieldHockeyScoreboard.ScoreboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Aliased"
        SnapsToDevicePixels="True"
        Title="Табло"
        Width="560" Height="240"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        Left="0" Top="0"
        AllowsTransparency="False"
        Background="#000000"
        ShowInTaskbar="False">

    <Window.Resources>
        <FontFamily x:Key="Seg7">pack://application:,,,/Fonts/#DSEG7 Classic</FontFamily>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Team A name (left) | Period (center) | Team B name (right) -->
        <Border Grid.Row="0" Background="#0a0a0a">
            <Grid Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding TeamAName}"
                           FontFamily="Consolas" FontSize="26" FontWeight="Bold"
                           Foreground="#FFFFFF"
                           SnapsToDevicePixels="True"
                           TextOptions.TextRenderingMode="Aliased"
                           TextOptions.TextFormattingMode="Display"
                           HorizontalAlignment="Left" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>

                <TextBlock Grid.Column="1" Text="{Binding Period}"
                           FontFamily="Consolas" FontSize="22" FontWeight="Bold"
                           Foreground="#FF3333"
                           SnapsToDevicePixels="True"
                           TextOptions.TextRenderingMode="Aliased"
                           TextOptions.TextFormattingMode="Display"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="16,0"/>

                <TextBlock Grid.Column="2" Text="{Binding TeamBName}"
                           FontFamily="Consolas" FontSize="26" FontWeight="Bold"
                           Foreground="#FFFFFF"
                           SnapsToDevicePixels="True"
                           TextOptions.TextRenderingMode="Aliased"
                           TextOptions.TextFormattingMode="Display"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <!-- Row 1: Logo A | Score | Logo B -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="110"/>
            </Grid.ColumnDefinitions>

            <!-- Logo A — максимально крупно -->
            <Image Grid.Column="0" Source="{Binding LogoASource}"
                   Stretch="Uniform" Margin="6"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>

            <!-- Score -->
            <Viewbox Grid.Column="1" Stretch="Uniform" Margin="6,4">
                <TextBlock Text="{Binding ScoreDisplay}"
                           FontFamily="{StaticResource Seg7}"
                           Foreground="#FFCC00"/>
            </Viewbox>

            <!-- Logo B — максимально крупно -->
            <Image Grid.Column="2" Source="{Binding LogoBSource}"
                   Stretch="Uniform" Margin="6"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
        </Grid>

        <!-- Row 2: Timer (center, large) -->
        <Border Grid.Row="2" Background="#0a0a0a">
            <TextBlock Text="{Binding TimerDisplay}"
                       FontFamily="{StaticResource Seg7}"
                       FontSize="44"
                       Foreground="#FF3333"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
