<Window x:Class="FieldHockeyScoreboard.ScoreboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Aliased"
        SnapsToDevicePixels="True"
        Title="Табло"
        Width="560" Height="240"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        Left="0" Top="0"
        AllowsTransparency="False"
        Background="#000000"
        ShowInTaskbar="False">

    <Window.Resources>
        <FontFamily x:Key="Seg7">pack://application:,,,/Fonts/#DSEG7 Classic</FontFamily>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <!-- Row 0: LOGO + TEAM NAME + SCORE + TEAM NAME + LOGO -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="94"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="94"/>
            </Grid.ColumnDefinitions>

            <!-- Logo A -->
            <Border Grid.Column="0" Width="94" Margin="2,4">
                <Image Source="{Binding LogoASource}"
                       Width="90" Height="90" Stretch="Uniform"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
            </Border>

            <!-- Team A name -->
            <TextBlock Grid.Column="1"
                       Text="{Binding TeamAName}"
                       FontFamily="Consolas" FontSize="24" FontWeight="Bold"
                       Foreground="#FFFFFF"
                       SnapsToDevicePixels="True"
                       TextOptions.TextRenderingMode="Aliased"
                       TextOptions.TextFormattingMode="Display"
                       HorizontalAlignment="Left" VerticalAlignment="Center"
                       TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                       Margin="4,0"
                       MaxHeight="140"
                       LineHeight="26" LineStackingStrategy="BlockLineHeight"/>

            <!-- Score -->
            <Viewbox Grid.Column="2" Stretch="Uniform" Margin="6,10" MaxHeight="130">
                <TextBlock Text="{Binding ScoreDisplay}"
                           FontFamily="{StaticResource Seg7}"
                           Foreground="#FFCC00"/>
            </Viewbox>

            <!-- Team B name -->
            <TextBlock Grid.Column="3"
                       Text="{Binding TeamBName}"
                       FontFamily="Consolas" FontSize="24" FontWeight="Bold"
                       Foreground="#FFFFFF"
                       SnapsToDevicePixels="True"
                       TextOptions.TextRenderingMode="Aliased"
                       TextOptions.TextFormattingMode="Display"
                       HorizontalAlignment="Right" VerticalAlignment="Center"
                       TextAlignment="Right"
                       TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                       Margin="4,0"
                       MaxHeight="140"
                       LineHeight="26" LineStackingStrategy="BlockLineHeight"/>

            <!-- Logo B -->
            <Border Grid.Column="4" Width="94" Margin="2,4">
                <Image Source="{Binding LogoBSource}"
                       Width="90" Height="90" Stretch="Uniform"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
            </Border>
        </Grid>

        <!-- Row 1: Period + Timer -->
        <Border Grid.Row="1" Background="#0a0a0a">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Period (left) -->
                <TextBlock Grid.Column="0"
                           Text="{Binding Period}"
                           FontFamily="Consolas"
                           FontSize="28" FontWeight="Bold"
                           Foreground="#FF3333"
                           SnapsToDevicePixels="True"
                           TextOptions.TextRenderingMode="Aliased"
                           TextOptions.TextFormattingMode="Display"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"/>

                <!-- Timer (right) -->
                <TextBlock Grid.Column="1"
                           Text="{Binding TimerDisplay}"
                           FontFamily="{StaticResource Seg7}"
                           FontSize="56"
                           Foreground="#FF3333"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
