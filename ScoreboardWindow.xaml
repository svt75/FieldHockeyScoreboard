<Window x:Class="FieldHockeyScoreboard.ScoreboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Aliased"
        Title="Табло"
        Width="540" Height="260"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        Left="0" Top="0"
        AllowsTransparency="False"
        Background="#000000"
        ShowInTaskbar="False">

    <Window.Resources>
        <!-- Семисегментный шрифт -->
        <FontFamily x:Key="Seg7">pack://application:,,,/Fonts/#DSEG7 Classic</FontFamily>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="26"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Period -->
        <Border Grid.Row="0" Background="#0a0a0a">
            <TextBlock Text="{Binding Period}"
                       FontFamily="Consolas"
                       FontSize="18" FontWeight="Bold"
                       Foreground="#FF3333"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Row 1: Logos + Teams + Score -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <!-- Team A: logo + name -->
            <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Source="{Binding LogoASource}" Width="52" Height="52"
                       Stretch="Uniform" HorizontalAlignment="Center"
                       Margin="0,0,0,2" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                <TextBlock Text="{Binding TeamAName}"
                           FontFamily="Consolas"
                           FontSize="13" FontWeight="Bold"
                           Foreground="#CCCCCC"
                           HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="116"/>
            </StackPanel>

            <!-- Score — семисегментный, максимально крупно -->
            <Viewbox Grid.Column="1" Stretch="Uniform" Margin="4,6">
                <TextBlock Text="{Binding ScoreDisplay}"
                           FontFamily="{StaticResource Seg7}"
                           Foreground="#FFCC00"/>
            </Viewbox>

            <!-- Team B: logo + name -->
            <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Source="{Binding LogoBSource}" Width="52" Height="52"
                       Stretch="Uniform" HorizontalAlignment="Center"
                       Margin="0,0,0,2" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                <TextBlock Text="{Binding TeamBName}"
                           FontFamily="Consolas"
                           FontSize="13" FontWeight="Bold"
                           Foreground="#CCCCCC"
                           HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="116"/>
            </StackPanel>
        </Grid>

        <!-- Row 2: Cards + Timer -->
        <Border Grid.Row="2" Background="#0a0a0a">
            <Grid Margin="6,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Cards A -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="14" Height="14" Fill="#00FF00" Margin="0,0,3,0"/>
                    <TextBlock Text="{Binding GreenCardsA}" FontFamily="{StaticResource Seg7}" Foreground="#00FF00" FontSize="24" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <Ellipse Width="14" Height="14" Fill="#FFFF00" Margin="0,0,3,0"/>
                    <TextBlock Text="{Binding YellowCardsA}" FontFamily="{StaticResource Seg7}" Foreground="#FFFF00" FontSize="24" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Timer — семисегментный -->
                <Border Grid.Column="1" Background="#0f0000" Padding="12,2" Margin="6,4">
                    <TextBlock Text="{Binding TimerDisplay}"
                               FontFamily="{StaticResource Seg7}"
                               FontSize="36"
                               Foreground="#FF3333"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Cards B -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="14" Height="14" Fill="#00FF00" Margin="0,0,3,0"/>
                    <TextBlock Text="{Binding GreenCardsB}" FontFamily="{StaticResource Seg7}" Foreground="#00FF00" FontSize="24" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <Ellipse Width="14" Height="14" Fill="#FFFF00" Margin="0,0,3,0"/>
                    <TextBlock Text="{Binding YellowCardsB}" FontFamily="{StaticResource Seg7}" Foreground="#FFFF00" FontSize="24" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
