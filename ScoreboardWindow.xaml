<Window x:Class="FieldHockeyScoreboard.ScoreboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Aliased"
        Title="Табло"
        Width="560" Height="240"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        Left="0" Top="0"
        AllowsTransparency="False"
        Background="#000000"
        ShowInTaskbar="False">

    <Window.Resources>
        <FontFamily x:Key="Seg7">pack://application:,,,/Fonts/#DSEG7 Classic</FontFamily>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="26"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="38"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Team names — 2 lines each (name + city) -->
        <Grid Grid.Row="0" Margin="8,2,8,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Team A -->
            <StackPanel Grid.Column="0" HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock Text="{Binding TeamAName}"
                           FontFamily="Consolas" FontSize="20" FontWeight="Bold"
                           Foreground="#FFFFFF" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding TeamACityName}"
                           FontFamily="Consolas" FontSize="16" FontWeight="Bold"
                           Foreground="#AAAAAA" TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- Team B -->
            <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="{Binding TeamBName}"
                           FontFamily="Consolas" FontSize="20" FontWeight="Bold"
                           Foreground="#FFFFFF" TextTrimming="CharacterEllipsis"
                           HorizontalAlignment="Right"/>
                <TextBlock Text="{Binding TeamBCityName}"
                           FontFamily="Consolas" FontSize="16" FontWeight="Bold"
                           Foreground="#AAAAAA" TextTrimming="CharacterEllipsis"
                           HorizontalAlignment="Right"/>
            </StackPanel>
        </Grid>

        <!-- Row 1: Period -->
        <Border Grid.Row="1" Background="#0a0a0a">
            <TextBlock Text="{Binding Period}"
                       FontFamily="Consolas"
                       FontSize="20" FontWeight="Bold"
                       Foreground="#FF3333"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Row 2: Logo A + SCORE + Logo B -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="74"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="74"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" Source="{Binding LogoASource}"
                   Width="68" Height="68" Stretch="Uniform"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>

            <Viewbox Grid.Column="1" Stretch="Uniform" Margin="4,4">
                <TextBlock Text="{Binding ScoreDisplay}"
                           FontFamily="{StaticResource Seg7}"
                           Foreground="#FFCC00"/>
            </Viewbox>

            <Image Grid.Column="2" Source="{Binding LogoBSource}"
                   Width="68" Height="68" Stretch="Uniform"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"/>
        </Grid>

        <!-- Row 3: Timer -->
        <Border Grid.Row="3" Background="#0a0a0a">
            <TextBlock Text="{Binding TimerDisplay}"
                       FontFamily="{StaticResource Seg7}"
                       FontSize="32"
                       Foreground="#FF3333"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
